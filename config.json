{
  "model": "qwen3-coder:latest",
  "aider_model": "openai/qwen3-coder:latest",
  "max_blocks": 5,
  "max_attempts_per_block": 2,
  "timeout_minutes_per_aider_run": 30,
  "max_files_to_modify": 2,
  "max_files_to_read": 3,
  "prefer_api_alignment_tasks": true,
  "never_change_multiple_public_interfaces_in_one_block": true,
  "before_using_existing_function": "inspect_signature",
  "commands": {
    "test": "/Users/matsedenius/.pyenv/versions/3.10.13/bin/python -m pytest -q"
  },
  "protected_paths": [
    ".git",
    ".venv",
    "__pycache__"
  ],
  "nightshift_version": "0.3.0",
  "feature_id": "nightshift-self-development",
  "task_id": "task",
  "artifact_directory": "history",
  "architecture_approval_policy": "file",
  "roles": {
    "planner": {
      "provider": "ollama",
      "model": "qwen3-coder:latest",
      "context_policy": "isolated",
      "output_schema": "plan"
    },
    "architect": {
      "provider": "ollama",
      "model": "qwen3-coder:latest",
      "context_policy": "isolated",
      "output_schema": "architecture_contract"
    },
    "builder": {
      "provider": "ollama",
      "model": "openai/qwen3-coder:latest",
      "context_policy": "contract_only",
      "permissions": [
        "read_allowed_files",
        "modify_allowed_files"
      ],
      "output_schema": "implementation_result"
    },
    "reviewer": {
      "provider": "ollama",
      "model": "qwen3-coder:latest",
      "context_policy": "independent",
      "output_schema": "review_report"
    },
    "historian": {
      "provider": "local",
      "model": "deterministic",
      "context_policy": "artifacts_only",
      "output_schema": "retrospective"
    },
    "librarian": {
      "provider": "local",
      "model": "deterministic",
      "context_policy": "repository_only",
      "output_schema": "repo_map"
    }
  }
}
