{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nightshift.local/schema/project.schema.json",
  "title": "Nightshift Project Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
