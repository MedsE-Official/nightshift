{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nightshift.local/schema/prompts.schema.json",
  "title": "Nightshift Project Prompts",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "prompts": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "required": [
        "planner",
        "builder",
        "reviewer",
        "architect"
      ]
    }
  }
}
