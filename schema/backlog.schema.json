{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nightshift.local/schema/backlog.schema.json",
  "title": "Nightshift Backlog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "features"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "features": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/feature"
      }
    }
  },
  "$defs": {
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "tasks"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task"
          }
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "prompt",
        "files",
        "status",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "blocked",
            "failed",
            "done",
            "cancelled"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "events": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/event"
          }
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "message"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
