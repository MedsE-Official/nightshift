{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nightshift.local/schema/knowledge.schema.json",
  "title": "Nightshift Project Knowledge",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scope", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "scope": {
      "type": "string",
      "const": "project"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "content"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "content": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  }
}
